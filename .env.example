# PostgreSQL
# NOTE: Use 'localhost' when running backend with 'uv run uvicorn' (local dev)
#       Use 'postgres' when running everything inside Docker
POSTGRES_USER=advisor
POSTGRES_PASSWORD=advisor_secret
POSTGRES_DB=financial_advisor
DATABASE_URL=postgresql+asyncpg://advisor:advisor_secret@localhost:5432/financial_advisor

# MongoDB
MONGO_USER=advisor
MONGO_PASSWORD=advisor_secret
MONGO_DB=financial_advisor
MONGODB_URL=mongodb://advisor:advisor_secret@localhost:27017/financial_advisor?authSource=admin

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenRouter — all LLM calls (get key at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Market Data
ALPHA_VANTAGE_API_KEY=your_key_here
FRED_API_KEY=your_key_here

# Langfuse
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# App
APP_ENV=development
LOG_LEVEL=INFO
